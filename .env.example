# ============================================
# Core Platform Configuration
# ============================================
# Copy this file to .env and fill in the required values.
# Then run: docker compose up --build

# Application Name
APP_NAME="Core Platform"

# ============================================
# MongoDB Configuration (REQUIRED)
# ============================================
# Docker compose uses these for MongoDB initialization
MONGO_USER=app_admin
MONGO_PASSWORD=app_secure_pass
MONGO_DB=app_database

# Connection string for the backend
# When running in Docker:
MONGO_URI=mongodb://app_admin:app_secure_pass@app-mongo:27017/app_database?authSource=admin

# When running locally:
# MONGO_URI=mongodb://app_admin:app_secure_pass@localhost:27017/app_database?authSource=admin

# ============================================
# JWT Authentication (REQUIRED)
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-32-character-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ============================================
# Admin User (REQUIRED for initial setup)
# ============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourSecurePassword123!

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=["http://localhost:3100","http://localhost:5173","http://localhost:3000"]

# ============================================
# Redis Configuration (Optional)
# ============================================
REDIS_URL=redis://app-redis:6379

# ============================================
# Frontend URL (for email links)
# ============================================
APP_BASE_URL=http://localhost:3100

# ============================================
# Debug Mode (Optional)
# ============================================
DEBUG=false
