# ============================================
# SAIL Starter Kit Configuration
# ============================================
# Copy this file to .env and fill in the required values.
# Then run: docker compose up --build

# Application Name
APP_NAME="SAIL Starter Kit"

# ============================================
# MongoDB Configuration (REQUIRED)
# ============================================
# Docker compose uses these for MongoDB initialization
MONGO_USER=app_admin
MONGO_PASSWORD=app_secure_pass
MONGO_DB=app_database

# Connection string for the backend
# When running in Docker:
MONGO_URI=mongodb://app_admin:app_secure_pass@app-mongo:27017/app_database?authSource=admin

# When running locally:
# MONGO_URI=mongodb://app_admin:app_secure_pass@localhost:27017/app_database?authSource=admin

# ============================================
# JWT Authentication (REQUIRED)
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-32-character-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ============================================
# Admin User (REQUIRED for initial setup)
# ============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourSecurePassword123!

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=["http://localhost:3100","http://localhost:5173","http://localhost:3000"]

# ============================================
# Redis Configuration (Optional)
# ============================================
REDIS_URL=redis://app-redis:6379

# ============================================
# Frontend URL (for email links)
# ============================================
APP_BASE_URL=http://localhost:3100

# ============================================
# Debug Mode (Optional)
# ============================================
DEBUG=false

# ============================================
# Email Configuration
# ============================================
# Provider: console (logs only), smtp, or resend
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=SAIL Starter Kit

# --- SMTP Settings (when EMAIL_PROVIDER=smtp) ---
# Works with Gmail, Outlook, Yahoo, or any SMTP server
# For Gmail: use smtp.gmail.com and an "App Password"
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# --- Resend Settings (when EMAIL_PROVIDER=resend) ---
# Get your API key from https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# ============================================
# OTP Settings (Optional)
# ============================================
# Cooldown between OTP resends (seconds)
OTP_RESEND_COOLDOWN_SECONDS=120
# Master OTP for testing (leave empty in production!)
# MASTER_OTP=123456
